{{- $items := slice -}}
{{- range where site.RegularPages "Params.searchExclude" "!=" true -}}
  {{- $tags := slice -}}
  {{- range .GetTerms "tags" -}}
    {{- $tags = $tags | append .LinkTitle -}}
  {{- end -}}
  {{- $section := "" -}}
  {{- with .CurrentSection -}}
    {{- $section = .Title -}}
  {{- else -}}
    {{- $section = .Section -}}
  {{- end -}}
  {{- $date := "" -}}
  {{- if not .Date.IsZero -}}
    {{- $date = .Date.Format "January 2, 2006" -}}
  {{- end -}}
  {{- $items = $items | append (dict
    "title" .Title
    "url" .RelPermalink
    "section" $section
    "date" $date
    "summary" (.Summary | plainify | htmlUnescape)
    "content" (.Plain | htmlUnescape)
    "tags" $tags
  ) -}}
{{- end -}}
{{- $items | jsonify -}}
