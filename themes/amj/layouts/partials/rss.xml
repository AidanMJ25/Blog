{{- $ctx := .page -}}
{{- $pages := .pages -}}
{{- $self := .self -}}
{{- $fullText := site.Params.rssFullText | default false -}}
{{- printf "<?xml version=\"1.0\" encoding=\"utf-8\" standalone=\"yes\"?>" | safeHTML }}
<rss version="2.0" xmlns:atom="http://www.w3.org/2005/Atom" xmlns:content="http://purl.org/rss/1.0/modules/content/">
  <channel>
    <title>{{ printf "%s" .title | plainify | htmlUnescape }}</title>
    <link>{{ .link }}</link>
    <description>{{ printf "%s" .description | plainify | htmlUnescape }}</description>
    <language>{{ site.Language.Lang | default site.LanguageCode | default "en-us" }}</language>
    {{ with $self }}
      <atom:link href="{{ . }}" rel="self" type="application/rss+xml"></atom:link>
    {{ end }}
    {{ range first 50 $pages }}
      <item>
        <title>{{ printf "%s" .Title | plainify | htmlUnescape }}</title>
        <link>{{ .Permalink }}</link>
        <guid isPermaLink="true">{{ .Permalink }}</guid>
        {{ with .Date }}
          <pubDate>{{ .Format "Mon, 02 Jan 2006 15:04:05 -0700" }}</pubDate>
        {{ end }}
        {{ if $fullText }}
          <description>{{ printf "<![CDATA[%s]]>" .Content | safeHTML }}</description>
          <content:encoded>{{ printf "<![CDATA[%s]]>" .Content | safeHTML }}</content:encoded>
        {{ else }}
          {{ with .Summary }}
            <description>{{ printf "%s" . | plainify | htmlUnescape }}</description>
          {{ end }}
        {{ end }}
      </item>
    {{ end }}
  </channel>
</rss>
